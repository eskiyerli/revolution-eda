# Revolution EDA environment configuration
# Copy this file to .env and adjust values as needed.

# PDK path — relative paths are resolved relative to the project directory.
# An absolute path is used as-is.
REVEDA_PDK_PATH=defaultPDK

# Plugin path — when not set or empty, defaults to ~/.reveda/plugins/
# Relative paths are resolved relative to the project directory.
# Use ~/.reveda/plugins for the central plugin directory (Linux/macOS and Windows).
REVEDA_PLUGIN_PATH=~/.reveda/plugins

# The revedaLicense compiled module (.pyd/.so) is expected in the
# application root directory (the directory containing reveda.py) for
# development, or in ~/.reveda/revedaLicense/ for installed deployments.

# Other optional paths
# REVEDA_VA_MODULE_PATH=
